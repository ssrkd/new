# ════════════════════════════════════════════════════════════════
# .env.example — Дипломатическая аналитическая платформа
# Скопируй в .env и заполни значения
# НИКОГДА не коммить .env с реальными ключами!
# ════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── LLM (уже заполнены — взяты из dashboard.jsx) ─────────────
# OpenRouter (Gemini 2.5 Flash) — основной провайдер
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Groq (Llama 3.3 70B) — fallback, 4 ключа через round-robin
# Ключи уже встроены в config.py; сюда можно добавить дополнительный

# ── Telegram (Telethon) — опционально ────────────────────────
# Получить на https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Имя файла сессии (создаётся при первой авторизации)
TELEGRAM_SESSION=diplomat_session

# ── Опциональная защита API токеном ──────────────────────────
# Если установлен — все /api/* запросы требуют заголовок:
# Authorization: Bearer YOUR_TOKEN_HERE
# Оставь пустым для открытого доступа (localhost)
ACCESS_TOKEN=

# ── Embedding модель (local, без API ключа) ───────────────────
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# ── Расписание (минуты) ───────────────────────────────────────
INGESTION_INTERVAL_MINUTES=30
PROCESSING_INTERVAL_MINUTES=35
